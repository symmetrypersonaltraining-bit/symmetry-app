# Supabase — get these from your Supabase project dashboard:
# Settings → API → Project URL + Project API keys

NEXT_PUBLIC_SUPABASE_URL=https://mkfiginpiesospsnktea.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — for server-side admin operations (creating auth users, sending invites)
# Settings → API → service_role (keep this secret, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used in invite email redirect links
NEXT_PUBLIC_APP_URL=https://your-vercel-url.vercel.app
